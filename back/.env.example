# ─── Serveur ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL — Supabase ou Railway ────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://postgres:MON_MDP@db.xxx.supabase.co:5432/postgres?sslmode=require

# ─── Session ─────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=remplacer_par_une_chaine_aleatoire_de_48_caracteres_minimum

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=XXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXX
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Gmail de Cédric (seul autorisé à accéder à l'admin) ─────────────────────
ADMIN_EMAIL=cedric@gmail.com

# ─── Nodemailer (envoi d'emails) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=cedricgrimere@hotmail.com
# Mot de passe d'application Gmail (pas le mot de passe du compte)
# Générer sur : myaccount.google.com/security → Mots de passe des applications
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM="Cédric Grimere Photographe <cedricgrimere@hotmail.com>"

# ─── Cloudinary (stockage photos) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=mon_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXX

# ─── URL du frontend (CORS + redirections OAuth) ─────────────────────────────
# En dev : http://localhost:3000  |  En prod : https://cedricgrimere.fr
FRONTEND_URL=http://localhost:3000

# ─── URL du backend (pour les liens dans les emails) ─────────────────────────
# En dev : http://localhost:5000  |  En prod : https://cedric-grimere-back.onrender.com
BACKEND_URL=http://localhost:5000

# ─── En production (Render), remplacer par : ─────────────────────────────────
# GOOGLE_CALLBACK_URL=https://cedric-grimere-back.onrender.com/api/auth/google/callback
# FRONTEND_URL=https://cedricgrimere.fr
# BACKEND_URL=https://cedric-grimere-back.onrender.com
# NODE_ENV=production
